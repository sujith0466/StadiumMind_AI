# StadiumMind AI Backend - Environment Template
# DO NOT ADD REAL SECRETS HERE. This file is tracked by git.

# Flask settings
FLASK_APP=app.py
FLASK_ENV=production
SECRET_KEY=your_super_secret_flask_key_here
JWT_SECRET_KEY=your_super_secret_jwt_key_here
CORS_ORIGINS=https://your-frontend-domain.vercel.app

# Database Configuration (PostgreSQL/Supabase)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Redis Configuration (Optional, fallback to memory if omitted)
REDIS_URL=redis://user:password@host:6379/0

# Unified AI Gateway API Keys
OPENROUTER_API_KEY=your_openrouter_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# AI Configuration overrides (Optional)
AI_TIMEOUT=4.5
OPENROUTER_MODEL_PRIMARY=deepseek/deepseek-chat
OPENROUTER_MODEL_SECONDARY=qwen/qwen-2.5-72b-instruct

# Enable/Disable Local AI Fallback (true/false)
LOCAL_AI_FALLBACK_ENABLED=true
