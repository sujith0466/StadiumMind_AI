# Environment Configuration Template
# Copy this file to .env and fill in real values before deployment
# NEVER commit .env to version control (it is in .gitignore)

# =============================================
# Backend Flask Configuration
# =============================================
SECRET_KEY=replace-with-a-strong-random-secret-key
JWT_SECRET_KEY=replace-with-a-strong-jwt-secret-key

# =============================================
# PostgreSQL Database
# =============================================
DATABASE_URL=postgresql://stadium_admin:stadium_password@localhost:5432/stadium_mind

# =============================================
# Redis Cache
# =============================================
REDIS_URL=redis://localhost:6379/0

# =============================================
# Frontend (Vite)
# =============================================
VITE_API_BASE_URL=http://localhost:5000
